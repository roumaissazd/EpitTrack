@model EpitTrack.Models.Chauffeur

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Liste des chauffeurs</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="nom_chauff" class="control-label"></label>
                <input asp-for="nom_chauff" class="form-control" />
                <span asp-validation-for="nom_chauff" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="prenom_chauff" class="control-label"></label>
                <input asp-for="prenom_chauff" class="form-control" />
                <span asp-validation-for="prenom_chauff" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="adr_chauff" class="control-label"></label>
                <input asp-for="adr_chauff" class="form-control" />
                <span asp-validation-for="adr_chauff" class="text-danger"></span>
            </div>
            <div class="form-group">
            <label asp-for="cp_chauff" class="control-label"></label>
                <input asp-for="cp_chauff" class="form-control" />
                <span asp-validation-for="cp_chauff" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ville_chauff" class="control-label"></label>
                <input asp-for="ville_chauff" class="form-control" />
                <span asp-validation-for="ville_chauff" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="pays_chauff" class="control-label"></label>
                <input asp-for="pays_chauff" class="form-control" />
                <span asp-validation-for="pays_chauff" class="text-danger"></span>
            </div>
            <div class="form-group row">
                <div class="col-6">
                    <label asp-for="type_voiture_chauff" class="control-label"></label>
                    <select asp-for="type_voiture_chauff" name="type_voiture_chauff" asp-items="@ViewBag.typesVoiture">
                        <option>-- select type frais --</option>
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="hdispo_chauff" class="control-label"></label>
                <input asp-for="hdispo_chauff" class="form-control" />
                <span asp-validation-for="hdispo_chauff" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="position_chauff" class="control-label"></label>
                <input asp-for="position_chauff" class="form-control" />
                <span asp-validation-for="position_chauff" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="pos_chauff_long" class="control-label"></label>
                <input asp-for="pos_chauff_long" class="form-control" />
                <span asp-validation-for="pos_chauff_long" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="pos_chauff_lat" class="control-label"></label>
                <input asp-for="pos_chauff_lat" class="form-control" />
                <span asp-validation-for="pos_chauff_lat" class="text-danger"></span>
            </div>



            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
