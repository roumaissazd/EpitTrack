@model EpitTrack.Models.coutrh

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>
<hr />
<div class="card card-primary">
    <div class="card-header">
        <h3 class="card-title">Coût Ressource Humaine </h3>
    </div>
    <!-- /.card-header -->
    <!-- form start -->
    <form asp-action="Edit">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input type="hidden" asp-for="id_coutrh"/>
        <input type="hidden" asp-for="id_rh"/>
        <div class="card-body">
            <div class="row">
               
                <div class="col-sm-3">
                    <label asp-for="prenom_rh" class="control-label"></label>
                    <input asp-for="prenom_rh" class="form-control" readonly />
                    <span asp-validation-for="prenom_rh" class="text-danger"></span>
                </div>
                <div class="col-sm-3">
                    <label asp-for="nom_rh" class="control-label"></label>
                    <input asp-for="nom_rh" class="form-control" readonly />
                    <span asp-validation-for="nom_rh" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-3">
                    <label asp-for="date_deb_coutrh" class="control-label"></label>
                    <input asp-for="date_deb_coutrh" class="form-control"/>
                    <span asp-validation-for="date_deb_coutrh" class="text-danger"></span>
                </div>
                <div class="col-sm-3">
                    <label asp-for="date_fin_coutrh" class="control-label"></label>
                    <input asp-for="date_fin_coutrh" class="form-control" />
                    <span asp-validation-for="date_fin_coutrh" class="text-danger"></span>
                </div>
            </div>
            <div class="row">
                <div class="col-sm-3">
                    <label asp-for="mt_cout_paie" class="control-label"></label>
                <input asp-for="mt_cout_paie" class="form-control" />
                <span asp-validation-for="mt_cout_paie" class="text-danger"></span>
                </div>
                <div class="col-sm-3">
                    <label asp-for="mt_frais" class="control-label"></label>
                    <input asp-for="mt_frais" class="form-control" />
                    <span asp-validation-for="mt_frais" class="text-danger"></span>
                </div>
            </div>
        </div>
              <form asp-action="AnyTrivialString">
            <input type="submit" asp-route-id="@Model.id_coutrh" value="valider" asp-action="EditConfirmed" class="btn btn-primary" />
            </form>
        </form>
    </div>
<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
