@model EpitTrack.Models.frais

@{
    ViewData["Title"] = "Create";
}

<h1>Create</h1>

<h4>Frais</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group row">
                   <div class="col-6">
                    
                    <select asp-for="id_typefrais" name="id_typefrais" asp-items="@ViewBag.typesFrais">
                        <option>-- select type frais --</option>
                    </select>
                  </div>
           </div>
            <div class="form-group">
                <input type="hidden" asp-for="type_frais" value="test" />
            </div>
            <div class="form-group">
                <label asp-for="date_deb_frais" class="control-label"></label>
                <input asp-for="date_deb_frais" class="form-control" />
                <span asp-validation-for="date_deb_frais" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="date_fin_frais" class="control-label"></label>
                <input asp-for="date_fin_frais" class="form-control" />
                <span asp-validation-for="date_fin_frais" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="mt_frais_ht" class="control-label"></label>
                <input asp-for="mt_frais_ht" class="form-control" />
                <span asp-validation-for="mt_frais_ht" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="mt_frais_ttc" class="control-label"></label>
                <input asp-for="mt_frais_ttc" class="form-control" />
                <span asp-validation-for="mt_frais_ttc" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="comment_frais" class="control-label"></label>
                <input asp-for="comment_frais" class="form-control" />
                <span asp-validation-for="comment_frais" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
