@model IEnumerable<EpitTrack.Models.uber>
@{
    ViewData["Title"] = "Index";
}

 <!-- Small boxes (Stat box) -->
<div class="row">
    <div class="col-lg-3 col-6">
        <!-- small box -->
        <div class="small-box bg-info">
            <div class="inner">
                <h3>
                    @Model.Sum(course=>course.mt_verse) <sup style="font-size: 20px"> Euros</sup>
                </h3>
                
            </div>
            <div class="icon">
                <i class="ion ion-bag"></i>
            </div>
            <a href="#" class="small-box-footer">More info <i class="fas fa-arrow-circle-right"></i></a>
        </div>
        
        <di>
            <form action="Ubers/Importer" method="post" enctype="multipart/form-data">
                <title>Upload le fichier UBER</title>
                <input type="file" name="file" />
                <input type="submit" value="Envoyer" class="btn btn-primary"/>
            </form>



        </di>
    </div>
    
