@model EpitTrack.ViewModels.IndisponibiliteViewModel
@{
    ViewData["Title"] = "Details";
}

<style>
 #monDiv {
        display: none;
         }

#ListeCourseDiv {
        display: none;
    }

    input[type="text"] {
        width: 200px;
        /* Autres styles ici */
    }

</style>


<h1>Details</h1>
<head>
    <!-- ... autres inclusions ... -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
</head>

<div>
    <h4>Indisponibilités </h4>
    <hr />
    <dl class="row">
       <dt class="col-sm-2">
            @Html.DisplayNameFor(Model =>Model.notre_chauffeur.id_chauff)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(Model =>Model.notre_chauffeur.id_chauff)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(Model =>Model.notre_chauffeur.nom_chauff)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(Model =>Model.notre_chauffeur.nom_chauff)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(Model =>Model.notre_chauffeur.prenom_chauff)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(Model =>Model.notre_chauffeur.prenom_chauff)
        </dd>
    </dl>

    <dl class="row">
        <div class="card-body">
            <p style="font-size: 18px; font-weight: bold;">Absences &nbsp;&nbsp;<a href="javascript:AddAbsence();" style="font-size: 25px; font-weight: bold;text-decoration: underline;">+</a></p>
          
            <div id="monDiv">

                <form asp-action="CreateAbsence" method="post">
                    <div>
                        <input type="hidden" asp-for="@Model.notre_chauffeur.id_chauff" name="id_chauff" />
                        <input type="hidden" asp-for="@Model.notre_chauffeur.nom_chauff" name="nom_chauff" />
                        <input type="hidden" asp-for="@Model.notre_chauffeur.prenom_chauff" name="prenom_chauff" />
                        <input type="hidden" asp-for="@Model.notre_chauffeur" name="Chauffeur" />
                    </div>
                    <table class="table table-bordered table-striped">
                        <th width="200px">Date Deb Absence</th>
                        <th width="200px">Heure Deb Absence</th>
                        <th width="200px">Date Reprise</th>
                        <th width="200px">Heure Reprise</th>
                        <th width="200px">Motif Absence</th>
                        <th width="200px"></th>
                        <tr>
                            <td width="200px"><input type="date" id="date_deb_indispo_chauff" name="date_deb_indispo_chauff" /></td>
                            <td width="200px"><input type="time" id="num_deb_indispo_chauff" name="num_deb_indispo_chauff" />&nbsp;&nbsp;<input type="checkbox" id="jour_complet" name="jour_complet" value="true"/>Toute la journée</td>
                            <td width="200px"><input type="date" id="date_reprise" name="date_reprise" /></td>
                            <td width="200px"><input type="time" id="num_heure_reprise" name="num_heure_reprise" /></td>
                            <td width="200px">
                                 <select name="motif_indispo_chauff" id="motif_indispo_chauff" asp-items="@ViewBag.Motifs">
                                   <option>-- select type frais --</option>
                                 </select>
                            </td>
                            <td width="200px"><input type="submit" value="CreateAbsence" class="btn btn-primary" /></td>
                        </tr>
                    </table>
                </form>
            </div>
            <div>
                
            <table id="example2" class="table table-bordered table-striped">
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvelleIndisponibilite.date_deb_indispo_chauff)
                    </th>
                   <th>
                        @Html.DisplayNameFor(Model =>Model.NouvelleIndisponibilite.num_deb_indispo_chauff)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvelleIndisponibilite.date_reprise)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvelleIndisponibilite.num_heure_reprise)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvelleIndisponibilite.motif_indispo_chauff)
                    </th>
                    <th></th>
                    @foreach (var item in Model.IndisponibilitesExistantes)
                    {
                 <tr>
                   <td>
                                @(item.date_deb_indispo_chauff.ToString("dd/MM/yyyy"))
                   </td>
                         @if(item.jour_complet)
                                {
                                <td>Toute la journée </td>
                                }
                                else
                                {
                                <td>
                                @Html.DisplayFor(modelItem => item.str_heure_deb_indispo_chauff)
                                </td>
                                }
                   
                   <td>
                                @(item.date_reprise.ToString("dd/MM/yyyy"))
                   </td>
                   <td>
                     @Html.DisplayFor(modelItem => item.str_heure_reprise)
                   </td>
                   <td>
                    @Html.DisplayFor(modelItem => item.motif_indispo_chauff)
                   </td>
                            <td>
                                <a asp-action="DeleteAbsence" asp-controller="Chauffeurs" asp-route-id_chauff="@item.id_chauff" asp-route-id_indps="@item.id_indispo">Supprimer</a>
                            </td>
                </tr>
                }
            </table>
        <div>
               <p style="font-size: 15px; font-weight: bold;">Preplanifications</p>
        </div>
                <table id="example3" class="table table-bordered table-striped">
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.id_course)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.date_course)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.Lacourse.nom_passagers)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.Lacourse.adr_depart)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.Lacourse.adr_arrivee)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.Lacourse.heur_deb_course)
                    </th>
                    <th>
                        @Html.DisplayNameFor(Model =>Model.NouvellePreplanif.Lacourse.heur_fin_course)
                    </th>
                    <th></th>
                    @foreach (var item in Model.PreplanifExistantes)
                    {
                        <tr>
                            <td>
                                @Html.DisplayFor(modelItem => item.Lacourse.id_course)
                            </td>
                            <td>
                                @(item.date_course.ToString("dd/MM/yyyy"))
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Lacourse.nom_passagers)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Lacourse.adr_depart)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Lacourse.adr_arrivee)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Lacourse.heur_deb_course)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Lacourse.heur_fin_course)
                            </td>

                            <td>
                                <a asp-action="DeletePreplanif" asp-controller="Chauffeurs" asp-route-id_chauff="@item.id_chauff" asp-route-id_preplan="@item.id_preplanif">Supprimer</a>
                            </td>
                        </tr>
                    }
                </table>
        </div>
        </div>
    </dl>
    <div>
    <a asp-action="Index">Back to List</a>
</div>
</div>
</div>



<script>
function AddAbsence() 
 {
   var div = document.getElementById("monDiv");
      if (div.style.display == "none") 
       {
            div.style.display = "block";
       } 
        else
        {
              div.style.display = "none";
        }
 }

@section Scripts 
{
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
</script>
<script>
        document.getElementById('date_reprise').onchange = function() {
        var dateDebut = document.getElementById('date_deb_indispo_chauff').value;
        var dateReprise = this.value;

            if (new Date(dateReprise) < new Date(dateDebut)) {
            alert('La date de reprise doit être supérieure ou égale à la date de début.');
            this.value = '';
        }
    };
    document.getElementById('date_deb_indispo_chauff').onchange = function () {
        var dateReprise = document.getElementById('date_reprise').value;
        var dateDeb = this.value;

        if (new Date(dateReprise) < new Date(dateDeb)) {
            alert('La date de début doit être inférieur ou égale à la date de reprise.');
            this.value = '';
        }
    };
    document.getElementById('jour_complet').onchange =function()
    {
        var checkbox = document.getElementById('jour_complet');
        if (checkbox.checked) {
            document.getElementById('num_deb_indispo_chauff').disabled = true;
        }
        else
        {
            document.getElementById('num_deb_indispo_chauff').disabled = false;
        }
    };
        
</script>
