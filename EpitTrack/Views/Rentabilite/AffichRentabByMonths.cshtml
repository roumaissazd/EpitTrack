@{
    ViewBag.Title = "Facture | Epilobe";

    @model IEnumerable<Rentabilite>;
}
 
<style>
    #div_RentabByDays {
    }
</style>
@section PageTitle{
    <h1 class="page-title">
        Gestion des Factures
        <small>Génération, Validation, Envoi ...</small>
    </h1>
}
@section PageBar{
    <ul class="page-breadcrumb">
        <li>
            <a href="../../">Accueil</a>
            <i class="fa fa-circle"></i>
        </li>
        <li>
            <span>Suivi Rentabilite</span>
        </li>
    </ul>
}


<div class="row">
    <div class="col-md-12">
        <div class="portlet light bordered">

            <div class="portlet-body">
                <table id="PlanningGrid" class="table table-striped table-hover PlanningTable" cellspacing="0">
                    <thead>
                        <tr>
                            <th></th>
                            <th></th>
                            <th>Mois</th>
                            <th>Nbre Courses</th>
                            <th>Nbre KM Estimés</th>
                            <th>Nbre KM Réels</th>
                            <th>Pv HT KM</th>
                            <th>CA HT</th>
                            <th>Coûts Fixes</th>
                            <th>Coûts Chauffeurs</th>
                            <th>Coûts Carburant</th>
                            <th>Marge Brute HT</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var Rm in Model)
                        {
                        <tr id="@Rm.mois_courses" style="cursor: pointer;">
                            <td>
                                <a href="#" onclick="Affich_Rentab_By_Days('@Rm.annee_courses','@Rm.mois_courses')">
                                    <img src="http://ceu.univ-lorraine.fr/files/2015/06/calendrier-700x675.jpg" width="20px">
                                </a>
                            </td>
                            <td>
                                <a href="#" onclick="Affich_Rentab_By_Month_By_Clt('@Rm.annee_courses','@Rm.mois_courses')">
                                    <img src="https://us.123rf.com/450wm/faysalfarhan/faysalfarhan1503/faysalfarhan150300757/37751427-client-membre-ic%20ne-du-bouton-carr%20-bleu-cyan.jpg?ver=6" width="20px">
                                </a>
                            </td>
                            <td>@Rm.lib_mois_courses</td>
                            <td>@Rm.nb_courses.ToString("# ###.00")</td>
                            <td>@Rm.nb_km_inclus.ToString("# ###.00")</td>
                            <td>@Rm.nb_km_reels.ToString("# ###.00")</td>
                            <td>@Rm.prix_vente_km.ToString("# ###.00")</td>
                            <td>@Rm.prix_vente_ht.ToString("# ###.00")</td>
                            <td>@Rm.cout_fixe.ToString("# ###.00")</td>
                            <td>@Rm.cout_chauffeur.ToString("# ###.00")</td>
                            <td>@Rm.cout_carburant.ToString("# ###.00")</td>
                            <td>@Rm.marge_brute.ToString("# ###.00")</td>
                        </tr>
                            <tr>
                                <td colspan="12">
                                    <table id="@("RentabByDays"+Rm.mois_courses)"></table>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="12">
                                    <table id="@("RentabByMonthClt"+Rm.mois_courses)"></table>
                                </td>
                            </tr>

                        }

                    </tbody>
                </table>

            </div>
        </div>
    </div>
</div>


<script>

    function Affich_Rentab_By_Days(v_annee,v_mois)
    {
        var x = document.getElementById("RentabByDays" + v_mois);
        if (x.style.display === "none")
        {

            x.style.display = "block";
        } else {

            x.style.display = "none";
        }

        $.ajax({
            type: 'POST',
            url: '../Rentabilite/AffichRentabByDays',
            data: {
                p_annee: v_annee,
                p_mois: v_mois,
            },
            success: function (data) {

                $('#RentabByDays' + v_mois).html(data);
            }

        });

    }
    function Affich_Rentab_By_Month_By_Clt(v_annee, v_mois)
    {
        
        var x = document.getElementById("RentabByMonthClt" + v_mois);
        if (x.style.display === "none") {

            x.style.display = "block";
        } else {

            x.style.display = "none";
        }
        
        $.ajax({
            type: 'POST',
            url: '../Rentabilite/AffichRentabByMonthByClients',
            data: {
                p_annee: v_annee,
                p_mois: v_mois,
            },
            success: function (data) {
        
                $('#RentabByMonthClt' + v_mois).html(data);
            }

        });

    }

</script>
