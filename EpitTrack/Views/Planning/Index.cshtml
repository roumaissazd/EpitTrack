    var id_interval;        
    if ('@Model.leplanif.val_compt>1' && '@Model.leplanif.pourcent_compt=<100') {

        
        id_interval =setInterval(Refresh, 3000);
    }


    document.getElementById('mode_auto').onchange = function () {
        var checkbox = document.getElementById('mode_auto');
        if (checkbox.checked) {
            document.getElementById('TpsAttente').disabled = true;
        }
        else {
            document.getElementById('TpsAttente').disabled = false;
        }
    };



    function Refresh() {
        var link = document.getElementById('initialiserPlanifLink');
        
        var idPlanif = link.href.split('=')[1];
        if (idPlanif > 0)
        {
            $.ajax({
                url: '@Url.Action("RefreshPlanification", "Planning")', // Assurez-vous que cette partie s'exécute dans le contexte Razor
            method: 'GET',
                data: { id_planif: idPlanif },
            success: function (data) {
                   
                // Mettre à jour le contenu de la vue partielle
                $('#planificationContainer').html(data);
                    $('#example1').DataTable();

                },
            error: function () {
            }
        });
        }

    }


    function Rafraichir(idPlanif) {
       
        var link = document.getElementById('initialiserPlanifLink');
        var LinkGen = document.getElementById('visualiserPlanifLink');
        
        link.href = '/Planning/Initialiser_Planif?id_planif=' + idPlanif.value;
        LinkGen.href = '/Planning/visualiser_planning?id_planif=' + idPlanif.value;
        
        $.ajax({
            url: '@Url.Action("RefreshPlanification", "Planning")', // Assurez-vous que cette partie s'exécute dans le contexte Razor
            method: 'GET',
            data: { id_planif: idPlanif.value },
            success: function (data) 
            {     
                // Mettre à jour le contenu de la vue partielle
                $('#planificationContainer').html(data);
                $('#example1').DataTable().draw();
            },
            error: function () 
            {
                alert("erreur " + idPlanif.value)
            }
        });
    }

    

