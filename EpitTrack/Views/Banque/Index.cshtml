        <script>
            //setInterval(Rafraichir, 30000);

            // setTimeout(function () {
            //    window.location.reload(1);
            // }, 30000); // 30000 milliseconds = 30 seconds
            function chargerSC(selectElement) {
                var IdClass = selectElement.options[selectElement.selectedIndex].value;

                $.ajax(
                 {
                    url: '/Banque/ChargerSc', // Assurez-vous que cette URL correspond à votre action de contrôleur
                    type: 'POST',
                    data: { p_idclass: IdClass },
                    success: function (response) {
                        if (Array.isArray(response)) {
                            let liste = '<select id="divSelectSC_' + selectElement.id + '"><option>--select sous class --</option>';
                            response.forEach(sc => {
                                liste += '<option value=' + sc.Value + '>' + sc.Text + '</option>';
                            });
                            liste += '</select>';
                           // var td_a_modifier = $(selectElement).closest('tr').find('td').eq(7); // Modifier selon votre structure HTML
                           // td_a_modifier.html(liste);

                            // Récupérer l'élément select avec l'ID spécifique
                            var selectSClass = $('select#SelectSClass_' + selectElement.id.split('_')[1]); // Modifier selon votre ID spécifique
                            selectSClass.html(liste);
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error("Erreur lors de la requête AJAX : ", error);
                        // Gérer l'erreur ici
                    }
                }
                );
            }



            function Rafraichir() {
                $.ajax({
                    url: '@Url.Action("Actualiser", "Planning")',
                    method: 'GET',
                    success: function (data) {
                        window.location.reload();
                    }
                });
            };

            $(document).ready(function () {

                




















                $('.btn-affecter').click(function () {

                    var IdBanque = $(this).data('id');
                    var IdClass = $("#SelectClass_" + IdBanque).val();
                    var ClasseSelectionnee = $("#SelectClass_" + IdBanque + " option:selected").text();

                    if (ClasseSelectionnee.length > 0) {
                        Affect_class(IdBanque, IdClass, ClasseSelectionnee);

                    };
                });
                function Affect_class(idbanque, idclass, classe_selectionnee) 
                {
                    $.ajax(
                        
                    {
                        url: '/banque/Affecter_class', // Vérifiez que cette URL est correcte.
                        type: 'POST',
                        data: { p_idbanque: idbanque, p_idclass: idclass},
                        success: function (response) 
                        {
                            $('#divAnnulC_'  + idbanque + ' label').remove();
                            $('#divAnnulC_'  + idbanque).append($('<label>').text(classe_selectionnee));
                            $('#divSelectC_' + idbanque).hide();
                            $('#divAnnulC_'  + idbanque).show();
                            $('#divSelectSC_' + idbanque).show();
                            $('#divAnnulSC_' + idbanque).hide();
                                
                        },
                        error: function (xhr, status, error) 
                        {
                            console.error("Erreur lors de l'affectation : ", error);
                            // Ici, vous pouvez ajouter une logique pour afficher l'erreur à l'utilisateur.
                        }
                    });
                };

                $('.btn-annuler-affect').click(function () 
                {
                    var IdBanque = $(this).data('id');
                    $('#divSelectC_' + IdBanque).show();
                    $('#divAnnulC_' + IdBanque).hide();
                    Annuler_Affect_C(IdBanque)
                });

                function Annuler_Affect_C(idbanque) 
                {
                    $.ajax(
                        
                    {
                        url: '/banque/Annuler_Affect_C', // Vérifiez que cette URL est correcte.
                        type: 'POST',
                        data: { p_idbanque: idbanque},
                        success: function (response) 
                        {}
                    });
                };



                




                $('.btn-affecter_sc').click(function () {

                    var IdBanque = $(this).data('id');
                    var Id_sous_class = $("#divSelectSC_" + IdBanque).val();
                    var IdClass = $("#SelectClass_" + IdBanque).val();
                    var Sous_classeSelectionnee = $("#SelectSClass_" + IdBanque + " option:selected").text();

                    

                    if (Sous_classeSelectionnee.length > 0) {
                        Affect_sous_class(IdBanque, Id_sous_class, Sous_classeSelectionnee);

                    };
                    var ClasseSelectionnee = $("#SelectClass_" + IdBanque + " option:selected").text();

                    if (ClasseSelectionnee.length > 0) {
                        Affect_class(IdBanque, IdClass, ClasseSelectionnee);

                    };
                });
                function Affect_sous_class(idbanque, id_sous_class, sous_classeSelectionnee) {
                    $.ajax(

                        {
                            url: '/banque/Affecter_sous_class', // Vérifiez que cette URL est correcte.
                            type: 'POST',
                            data: { p_idbanque: idbanque, p_id_sous_class: id_sous_class },
                            success: function (response) {
                                $('#divAnnulSC_' + idbanque + ' label').remove();
                                $('#divAnnulSC_' + idbanque).append($('<label>').text(sous_classeSelectionnee));
                                $('#divSelectSC_' + idbanque).hide();
                                $('#divAnnulSC_' + idbanque).show();
                            },
                            error: function (xhr, status, error) {
                                console.error("Erreur lors de l'affectation : ", error);
                                // Ici, vous pouvez ajouter une logique pour afficher l'erreur à l'utilisateur.
                            }
                        });
                };
                
            });
            @section Scripts {
