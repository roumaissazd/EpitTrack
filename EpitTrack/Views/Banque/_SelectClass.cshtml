@model EpitTrack.ViewModels.SelectClassViewModel;

@{
    var classesOperations = Model.lesClassesOperations;
}
<style>
    /* Popup container */
    .popup {
        position: relative;
        display: inline-block;
        cursor: pointer;
    }

        /* The actual popup (appears on top) */
        .popup .popuptext {
            visibility: hidden;
            width: 50px;
            background-color: #555;
            color: #fff;
            text-align: center;
            border-radius: 6px;
            padding: 8px 0;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            margin-left: -80px;
        }

            /* Popup arrow */
            .popup .popuptext::after {
                content: "";
                position: absolute;
                top: 100%;
                left: 50%;
                margin-left: -5px;
                border-width: 5px;
                border-style: solid;
                border-color: #555 transparent transparent transparent;
            }

        /* Toggle this class when clicking on the popup container (hide and show the popup) */
        .popup .show {
            visibility: visible;
            -webkit-animation: fadeIn 1s;
            animation: fadeIn 1s
        }


    .btn-centered {
        display: block; /* Affiche le bouton comme un bloc */
        width: 150px; /* Largeur fixe du bouton */
        height: 50px; /* Hauteur fixe du bouton */
        line-height: 50px; /* Hauteur de ligne égale ŕ la hauteur du bouton pour centrer verticalement le texte */
        margin: 0 auto; /* Marges automatiques sur les côtés pour centrer horizontalement */
        text-align: center; /* Centrer le texte ŕ l'intérieur du bouton horizontalement */
        padding: 0; /* Pas de padding pour que line-height contrôle l'alignement vertical */
    }

    .progress {
        width: 100%;
        background-color: #ddd;
    }

    .progress-bar {
        height: 20px;
        background-color: #4CAF50;
        text-align: center;
        line-height: 20px;
        color: white;
    }

    .scrollable {
        overflow-x: auto; /* Active le défilement horizontal si nécessaire */
    }
</style>
<div class="select-container">
    <h1>ID passé : @Model.banque_op.id_banque</h1>
    @if (classesOperations != null && classesOperations.Any())
    {
        <select class="selectClass">
            <option value="">- Select class -</option>
            @foreach (var classe in classesOperations)
            {
                <option value="@classe.id_class_op">@classe.lib_class_op</option>
            }
        </select>
        <button class="btn-affecter">Affecter</button>
        <button class="btn-annuler" style="display:none;">Annuler</button>
    }
    else
    {
        <p>No classes available</p>
    }
</div>
<script>
    $('.select-container .selectClass'+@Model.banque_op.id_banque).change(function ()
    {
        var container = $(this).closest('.select-container');

        var selectedOption = $(this).val();

        if (selectedOption) 
        {
            container.find('.btn-affecter').show();
            container.find('.btn-annuler').hide();
        } 
        else
        {
            container.find('.btn-affecter').hide();
            container.find('.btn-annuler').show();
        }
    });

    $('.select-container .btn-affecter').click(function () 
    {
        var container = $(this).closest('.select-container');
        var selectedOption = container.find('.selectClass'+@Model.banque_op.id_banque).val();
        alert(selectedOption)
        // Votre logique d'affectation ici
    });
    
    $('.select-container .btn-annuler').click(function () 
    {
        var container = $(this).closest('.select-container');
        container.find('.selectClass').val('');
        container.find('.btn-affecter').hide();
        container.find('.btn-annuler').hide();
    });
</script>